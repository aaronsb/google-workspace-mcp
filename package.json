{
  "name": "@aaronsb/google-workspace-mcp",
  "version": "2.7.1",
  "mcpName": "io.github.aaronsb/google-workspace",
  "description": "MCP server for Google Workspace with progressive context disclosure and multi-account orchestration",
  "repository": {
    "type": "git",
    "url": "https://github.com/aaronsb/google-workspace-mcp"
  },
  "type": "module",
  "bin": {
    "google-workspace-mcp": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc --skipLibCheck && rm -rf build/factory/manifest && cp -r src/factory/manifest build/factory/manifest",
    "type-check": "tsc --noEmit --skipLibCheck",
    "lint": "eslint \"src/**/*.ts\"",
    "watch": "tsc --watch --skipLibCheck",
    "test": "vitest run --exclude 'src/__tests__/integration/**'",
    "test:watch": "vitest --exclude 'src/__tests__/integration/**'",
    "test:integration": "vitest run src/__tests__/integration",
    "test:all": "vitest run"
  },
  "dependencies": {
    "@googleworkspace/cli": "^0.22.5",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "sanitize-html": "2.17.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/sanitize-html": "^2.16.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
